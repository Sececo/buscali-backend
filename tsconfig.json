{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "rootDir": "conductores-src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["conductores-src/**/*", "conductores-src/app.ts"],
  "exclude": ["node_modules", "**/*.spec.ts"]
}
